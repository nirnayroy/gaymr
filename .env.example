# Copy to .env for local dev. Never commit .env.

# --- Database ---
DATABASE_URL=postgres://gaymr:gaymr@localhost:5432/gaymr?sslmode=disable

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Clerk ---
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_JWT_ISSUER=https://...clerk.accounts.dev

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- AWS (managed provider) ---
AWS_REGION=us-east-1
AWS_GPU_REGION=ap-south-1            # where GPU nodes launch by default
AWS_GPU_AMI_PARAM=/aws/service/deeplearning/ami/x86_64/base-oss-nvidia-driver-gpu-ubuntu-22.04/latest/ami-id
AWS_GPU_KEYPAIR=gaymr-sunshine-mumbai
AWS_GPU_SG_ID=                       # optional: pre-created SG; empty = look up by name
AWS_GPU_SSH_KEY=$HOME/.ssh/gaymr-sunshine-mumbai.pem
AWS_PROVISION_SCRIPT=infra/sunshine-node/provision-remote.sh

# --- BYOC ---
BYOC_EXTERNAL_ID_SALT=replace_with_random_64_bytes
BYOC_PLATFORM_ACCOUNT_ID=471824291894

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=gaymr-api          # override per service
OTEL_TRACES_SAMPLER=parentbased_always_on   # 100% in dev

# --- Provider API keys (Phase 9) ---
VAST_AI_API_KEY=
RUNPOD_API_KEY=

# --- App ---
LOG_LEVEL=debug
PORT=8080
