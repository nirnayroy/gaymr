# Binaries
/bin/
/dist/
*.exe
*.test
*.out

# Go
/vendor/
/.go-cache/

# Node / Vite
node_modules/
/web/dist/
/web/.vite/
/web/coverage/

# Env / secrets — never commit
.env
.env.*
!.env.example
*.pem
*.key
.aws-credentials
secrets.json

# Terraform
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
!*.tfvars.example
.terraform.lock.hcl

# Phase 1 launch artifacts (per-machine, ephemeral)
/infra/sunshine-node/.last-instance-id
/infra/sunshine-node/.last-public-ip
/infra/sunshine-node/.last-launch.env
/infra/sunshine-node/.last-az

# IDE / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*.swo

# Test artifacts
/coverage.out
/coverage.html
/.testcontainers/

# Generated
/web/src/api/generated/

# Temp
/tmp/
*.log
